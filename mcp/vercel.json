{
  "version": 2,
  "routes": [
    {
      "src": "/openrouter-mcp(/.*)?",
      "dest": "/api/openrouter.py"
    },
    {
      "src": "/openrouter-health",
      "dest": "/api/openrouter.py"
    },
    {
      "src": "/mcp(/.*)?",
      "dest": "/api/mcp.py"
    },
    {
      "src": "/health",
      "dest": "/api/mcp.py"
    },
    {
      "src": "/api/v1/.*",
      "dest": "/api/mcp.py"
    },
    {
      "src": "/",
      "dest": "/api/mcp.py"
    }
  ],
  "functions": {
    "api/mcp.py": {
      "maxDuration": 90,
      "memory": 1024
    },
    "api/openrouter.py": {
      "maxDuration": 90,
      "memory": 512
    }
  }
}
