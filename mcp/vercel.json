{
  "version": 2,
  "builds": [
    {
      "src": "api/mcp.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/mcp(/.*)?",
      "dest": "/api/mcp.py"
    },
    {
      "src": "/health",
      "dest": "/api/mcp.py"
    },
    {
      "src": "/",
      "dest": "/api/mcp.py"
    }
  ],
  "functions": {
    "api/mcp.py": {
      "maxDuration": 60
    }
  }
}
